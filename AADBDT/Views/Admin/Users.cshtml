@model IEnumerable<BusinessLogic.Models.ApplicationUser>


<div class="login-card" style="max-width: 1100px; width: 95%; background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.1);">
    <div class="login-header mb-4">
        <h2 style="color: #06b6d4;">User Management</h2>
        <p style="color: rgba(255,255,255,0.6);">Modify profiles and subscription tiers</p>
    </div>

    <div class="table-responsive">
        <table class="table" style="color: white; vertical-align: middle;">
            <thead>
                <tr style="border-bottom: 2px solid rgba(255,255,255,0.1);">
                    <th>User Details</th>
                    <th>Current Package</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                        <td>
                            <div class="d-flex flex-column">
                                <span class="fw-bold">@user.FirstName @user.LastName</span>
                                <small style="color: rgba(255,255,255,0.5);">@user.Email</small>
                            </div>
                        </td>
                        <td>
                            <span class="badge" style="background: rgba(6, 182, 212, 0.2); color: #06b6d4; border: 1px solid rgba(6, 182, 212, 0.3);">
                                @user.Package
                            </span>
                        </td>
                        <td>
                            <form asp-action="UpdateUserPackage" method="post" class="d-flex gap-2 justify-content-end">
                                <input type="hidden" name="userId" value="@user.Id" />
                                <select name="newPackage" class="form-select form-select-sm"
                                        style="background: rgba(0,0,0,0.3); color: white; border: 1px solid rgba(255,255,255,0.1); width: auto;">
                                    @foreach (var pkg in Enum.GetValues(typeof(BusinessLogic.Enums.PackageType)))
                                    {
                                        <option value="@pkg" selected="@(user.Package.Equals(pkg))">@pkg</option>
                                    }
                                </select>
                                <button type="submit" class="btn btn-sm" style="background: #06b6d4; color: white;">
                                    Update
                                </button>
                            </form>
                        </td>
                        <td>
                            <div class="d-flex gap-2 justify-content-end align-items-center">
                                <a asp-action="UserDetails" asp-route-userId="@user.Id"
                                   class="social-btn text-decoration-none"
                                   style="padding: 6px 12px; font-size: 14px; flex: initial; width: auto;">
                                    <i class="bi bi-activity"></i> History
                                </a>

                                <form asp-action="UpdateUserPackage" method="post" class="d-flex gap-2 m-0">
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>