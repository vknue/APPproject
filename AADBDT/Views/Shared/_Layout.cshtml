@using Microsoft.AspNetCore.Identity
@using BusinessLogic.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@inject IPhotoService PhotoService


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AADBDT</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/loginForm.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AADBDT.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body {
            overflow: hidden;
            height: 100vh;
        }
        .navbar {
            margin: 20px;
            border-radius: 16px;
            background: rgba(255, 255, 255, 0.1) !important;
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.2) !important;
            z-index: 1000;
        }

        .page-wrapper {
            min-height: calc(100vh - 120px); 
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        footer {
            background: transparent;
            color: rgba(255, 255, 255, 0.6) !important;
            border: none !important;
        }
    </style>
    </style>
</head>
<body>
    @if (User.Identity.IsAuthenticated)
    {
        var user = await UserManager.GetUserAsync(User);
        var count = await PhotoService.GetTodayUploadCount(user.Id);
        var limit = BusinessLogic.Helpers.PackageHelper.GetDailyLimit(user.Package);

        <div id="packageModal" class="photo-modal" onclick="closePackageModal(event)">
            <div class="login-card" style="max-width: 450px; width: 95%;" onclick="event.stopPropagation()">
                <div class="login-header">
                    <h3>Change Package</h3>
                    <p>Changes take effect at midnight</p>
                </div>

                <form asp-controller="Account" asp-action="RequestPackageChange" method="post">
                    <div class="package-container d-flex flex-column gap-2">
                        @foreach (var pkg in Enum.GetValues(typeof(BusinessLogic.Enums.PackageType)))
                        {
                            <label class="package-card">
                                <input type="radio" name="newType" value="@pkg" @(user.Package.Equals(pkg) ? "checked" : "") />
                                <div class="card-content">
                                    <div class="card-info">
                                        <span class="package-title">@pkg</span>
                                        <span class="package-desc">@(user.Package.Equals(pkg) ? "Current Plan" : "Switch to this plan")</span>
                                    </div>
                                    <div class="selection-indicator"></div>
                                </div>
                            </label>
                        }
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn w-100">Confirm Change</button>
                        <button type="button" onclick="closePackageModal(event)" class="btn w-100" style="background: rgba(255,255,255,0.05);">Cancel</button>
                    </div>
                </form>
            </div>
        </div>

        <header>
            <nav class="navbar navbar-expand-sm navbar-dark shadow">
                <div class="container-fluid">
                    <a class="navbar-brand font-weight-bold" asp-controller="Home" asp-action="Index">AADBDT</a>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            @if (!User.IsInRole("Guest"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link social-btn d-flex align-items-center gap-2 mx-2"
                                       asp-controller="Photos"
                                       asp-action="Upload"
                                       id="uploadButton"
                                       style="flex: initial; width: auto;">
                                       
                                        <i class="bi bi-cloud-upload"></i> Upload Photo
                                    </a>
                                </li>
                            
                                <li class="nav-item px-3 d-flex align-items-center">
                                    <span class="badge bg-info me-2">@user.Package</span>
                                    <small class="text-white-50">@count / @limit Uploads</small>
                                    <button type="button" class="ms-3 btn btn-sm btn-outline-light" onclick="openPackageModal()">Change Plan</button>
                                </li>
                            }
                        </ul>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item d-flex align-items-center mx-2">
                                <a class="nav-link social-btn d-flex align-items-center gap-2"
                                   asp-controller="Admin" asp-action="Users"
                                   style="flex: initial; width: auto;">
                                    <i class="bi bi-shield-lock"></i>
                                    <span>Manage Users</span>
                                </a>
                            </li>
                        }
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </nav>
        </header>
    }
    else
    {
        <header>
            <nav class="navbar navbar-expand-sm navbar-dark shadow">
                <div class="container-fluid">
                    <a class="navbar-brand font-weight-bold" asp-controller="Home" asp-action="Index">AADBDT</a>
                    <partial name="_LoginPartial" />
                </div>
            </nav>
        </header>
    }

    <div id="alert-container" style="position: absolute; top: 100px; left: 50%; transform: translateX(-50%); z-index: 9999; width: 100%; max-width: 400px; pointer-events: none;">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger shadow-lg border-0" style="background: rgba(220, 38, 38, 0.9); backdrop-filter: blur(10px); color: white; pointer-events: auto;">
                @TempData["Error"]
            </div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success shadow-lg border-0" style="background: rgba(22, 163, 74, 0.9); backdrop-filter: blur(10px); color: white; pointer-events: auto;">
                @TempData["Success"]
            </div>
        }
    </div>

    <div class="page-wrapper">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-center">
        <div class="container">
            &copy; 2025 - AADBDT
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        function openPackageModal() { document.getElementById("packageModal").style.display = "flex"; }
        function closePackageModal(e) { document.getElementById("packageModal").style.display = "none"; }
        @if (ViewBag.ErrorMessage != null)
        {
                <script>alert("@ViewBag.ErrorMessage");</script>
        }
    </script>
</body>
</html>