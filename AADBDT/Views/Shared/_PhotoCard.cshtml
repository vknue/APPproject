@model BusinessLogic.Models.Photo
@using Microsoft.AspNetCore.Identity
@using System.Text.Encodings.Web
@inject UserManager<BusinessLogic.Models.ApplicationUser> UserManager


<div class="login-card photo-flex-card mb-4">
    <div class="card-image-wrapper" style="cursor: pointer;" onclick="openModal('@Model.ImageUrl')">
        <img src="@Model.ImageUrl" alt="Photo" />
    </div>

    <div class="card-info-wrapper text-start">
        <div class="login-header p-0 mb-2" style="text-align: left;">
            <h4 style="color: #06b6d4; font-size: 1.2rem; margin: 0;">
                @Model.User.FirstName @Model.User.LastName
            </h4>
            <small style="color: rgba(255,255,255,0.5);">@Model.UploadDate.ToString("MMM dd, yyyy")</small>
        </div>

        <p style="color: white; font-size: 1rem; margin-bottom: 12px;">@Model.Description</p>

        <div class="hashtags-container">
            @foreach (var tag in Model.Hashtags?.Split(',') ?? Array.Empty<string>())
            {
                <span class="badge" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); margin-right: 5px;">
                    #@tag.Trim().Replace("#", "")
                </span>
            }
        </div>
        <div class="d-flex flex-wrap gap-2 w-100 mt-3">
            <button class="btn flex-fill d-flex align-items-center justify-content-center"
                    style="min-width: 40px;" onclick="openDownloadModal(@Model.Id)" title="Download">
                <i class="bi bi-download"></i>
            </button>

            @if (User.Identity.IsAuthenticated && Model.UserId == UserManager.GetUserId(User) || User.IsInRole("Admin"))
            {
                <button class="btn flex-fill d-flex align-items-center justify-content-center"
                        style="min-width: 40px; background: rgba(255, 255, 255, 0.1);"
                        onclick="openEditModal(@Model.Id, '@JavaScriptEncoder.Default.Encode(Model.Description)', '@JavaScriptEncoder.Default.Encode(Model.Hashtags)')" title="Edit">
                    <i class="bi bi-pencil"></i>
                </button>

                <form asp-controller="Photos" asp-action="Delete" asp-route-id="@Model.Id" method="post"
                      class="flex-fill" onsubmit="return confirm('Are you sure you want to delete this photo?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn w-100 d-flex align-items-center justify-content-center"
                            style="min-width: 40px; background: rgba(220, 38, 38, 0.2); border: 1px solid rgba(220, 38, 38, 0.4);" title="Delete">
                        <i class="bi bi-trash text-danger"></i>
                    </button>
                </form>
            }
        </div>
    </div>
</div>