@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/loginForm.css">
</head>
<body id="reglog">
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <h2>Reset Password</h2>
                <p>Enter your email to receive a reset link</p>
            </div>

            <form method="post">
                @* Validation Summary *@
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert" style="list-style:none; color:#ef4444; font-size:14px; margin-bottom:15px;"></div>

                <div class="form-group">
                    <div class="input-wrapper">
                        @* Note: Using 'required' to trigger the CSS :valid state for floating labels *@
                        <input asp-for="Input.Email" required autocomplete="username" aria-required="true" placeholder=" " />
                        <label asp-for="Input.Email">Email Address</label>
                        <span class="focus-border"></span>
                    </div>
                    <span asp-validation-for="Input.Email" class="error-message show"></span>
                </div>

                <button type="submit" class="login-btn btn">
                    <span class="btn-text">Send Reset Link</span>
                    <span class="btn-loader"></span>
                </button>

                <div class="signup-link">
                    <p>Remembered your password? <a asp-page="./Login">Back to Login</a></p>
                </div>
            </form>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>