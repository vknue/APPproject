@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/loginForm.css">
</head>
<body id="reglog">
    <div class="login-container" style="max-width: 500px;">
        <div class="login-card">
            <div class="login-header">
                <h2>Create Account</h2>
                <p>Join us and start sharing photos</p>
            </div>

            <form id="registerForm" asp-controller="Account" asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group">
                    <div class="input-wrapper">
                        <input name="firstName" required placeholder=" " />
                        <label>First Name</label>
                        <span class="focus-border"></span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="input-wrapper">
                        <input name="lastName" required placeholder=" " />
                        <label>Last Name</label>
                        <span class="focus-border"></span>
                    </div>
                </div>

                <div class="form-group">
                    <div class="input-wrapper">
                        <input name="email" type="email" required autocomplete="username" placeholder=" " />
                        <label>Email Address</label>
                        <span class="focus-border"></span>
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger" style="font-size:12px;"></span>
                </div>

                <div class="form-group">
                    <div class="input-wrapper">
                        <input name="password" type="password" required autocomplete="new-password" placeholder=" " />
                        <label>Password</label>
                        <span class="focus-border"></span>
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger" style="font-size:12px;"></span>
                </div>

                <div class="form-group">
                    <div class="input-wrapper">
                        <input name="confirmPassword" type="password" required autocomplete="new-password" placeholder=" " />
                        <label>Confirm Password</label>
                        <span class="focus-border"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label style="color: white; font-size: 14px; margin-bottom: 12px; display: block;">Select Package</label>
                    <div class="package-container d-flex flex-column gap-2">

                        <label class="package-card">
                            <input type="radio" name="package" value="FREE" checked />
                            <div class="card-content">
                                <div class="card-info">
                                    <span class="package-title">FREE</span>
                                    <span class="package-desc">Basic uploads, standard storage</span>
                                </div>
                                <div class="card-price">5€</div>
                            </div>
                        </label>

                        <label class="package-card">
                            <input type="radio" name="package" value="PRO" />
                            <div class="card-content">
                                <div class="card-info">
                                    <span class="package-title">PRO</span>
                                    <span class="package-desc">Higher limits, advanced filters</span>
                                </div>
                                <div class="card-price">10€</div>
                            </div>
                        </label>

                        <label class="package-card">
                            <input type="radio" name="package" value="GOLD" />
                            <div class="card-content">
                                <div class="card-info">
                                    <span class="package-title">GOLD</span>
                                    <span class="package-desc">Unlimited storage, priority support</span>
                                </div>
                                <div class="card-price">15€</div>
                            </div>
                        </label>

                    </div>
                </div>

                <button id="registerSubmit" type="submit" class="login-btn btn">
                    <span class="btn-text">Register</span>
                    <span class="btn-loader"></span>
                </button>
            </form>

            <div class="divider">
                <span>or register with</span>
            </div>

            <div class="social-login">
                <form asp-controller="Account" asp-action="ExternalLogin" method="post" class="social-login" style="width:100%; display: flex; gap: 10px;">
                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit" class="social-btn @(provider.Name.ToLower())-btn" name="provider" value="@provider.Name" style="flex: 1;">
                            <span class="social-icon @(provider.Name.ToLower())-icon"></span>
                            @provider.DisplayName
                        </button>
                    }
                </form>
            </div>

            <div class="signup-link">
                <p>Already have an account? <a asp-page="./Login">Sign In</a></p>
            </div>
        </div>
    </div>

    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>