@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AADBDT</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/loginForm.css" asp-append-version="true" />
</head>
<body id="reglog">
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <h2>Welcome</h2>
                <p>Sign in to your account</p>
            </div>

            <form class="login-form" id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert" style="list-style:none; font-size: 0.8rem; margin-bottom: 10px;"></div>

                <div class="form-group">
                    <div class="input-wrapper">
                        <input asp-for="Input.Email" required autocomplete="username" aria-required="true" placeholder=" " />
                        <label asp-for="Input.Email">Email Address</label>
                        <span class="focus-border"></span>
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

                <div class="form-group">
                    <div class="input-wrapper password-wrapper">
                        <input asp-for="Input.Password" required autocomplete="current-password" aria-required="true" placeholder=" " />
                        <label asp-for="Input.Password">Password</label>
                        <button type="button" class="password-toggle" id="passwordToggle" aria-label="Toggle password visibility">
                            <span class="eye-icon"></span>
                        </button>
                        <span class="focus-border"></span>
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger" style="font-size: 0.7rem;"></span>
                </div>

                <div class="form-options">
                    <label class="remember-wrapper">
                        <input asp-for="Input.RememberMe" />
                        <span class="checkbox-label">
                            <span class="checkmark"></span>
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </span>
                    </label>
                </div>

                <button id="login-submit" type="submit" class="login-btn btn">
                    <span class="btn-text">Sign In</span>
                    <span class="btn-loader"></span>
                </button>
            </form>

            <div class="divider">
                <span>or continue with</span>
            </div>

            <div class="social-login">
                @if ((Model.ExternalLogins?.Count ?? 0) > 0)
                {
                    <form asp-controller="Account" asp-action="ExternalLogin" method="post" class="social-login" style="width:100%; display: flex; gap: 10px;">
                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <button type="submit" class="social-btn @(provider.Name.ToLower())-btn" name="provider" value="@provider.Name" style="flex: 1;">
                                <span class="social-icon @(provider.Name.ToLower())-icon"></span>
                                @provider.DisplayName
                            </button>
                        }
                    </form>
                }
            </div>

            <div class="guest-login" style="margin-top: 15px;">
                <form asp-controller="Account" asp-action="GuestLogin" method="post" style="width:100%">
                    <button type="submit" class="social-btn guest-btn" style="width: 100%; justify-content: center; gap: 10px;">
                        <span class="social-icon guest-icon"></span>
                        Continue as Guest
                    </button>
                </form>
            </div>

            <div class="signup-link">
                <p>Don't have an account? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Sign up</a></p>
            </div>
        </div>
    </div>

    @* Scripts *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/script.js"></script>
    <script src="~/js/loginForm.js"></script>

    @* Browser Refresh for Development *@
    @inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
    @if (Env.EnvironmentName == "Development")
    {
        <script src="/_framework/aspnetcore-browser-refresh.js"></script>
    }
</body>
</html>